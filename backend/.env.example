# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Environment ─────────────────────────────────────────────────────────────
# "development" enables the local session interceptor and /auth/local-login.
# "production"  disables all of the above; the KVD proxy injects the header.
ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (Phase 1 - local):
DATABASE_URL=sqlite:///./ripple_grader.db
# PostgreSQL (Phase 2 - cloud), uncomment and set:
# DATABASE_URL=postgresql://user:password@host:5432/ripple_grader

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173

# ── Dev session (ignored when ENV=production) ────────────────────────────────
SESSION_COOKIE_NAME=dev_session_id
SESSION_TTL_HOURS=8
